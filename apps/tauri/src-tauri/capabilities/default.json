{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Default permissions for the Dusk Wallet main window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "stronghold:default",
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/dusk-wallet.hold"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPDATA/dusk-wallet.hold"
        }
      ]
    }
  ]
}